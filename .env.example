# Backend
EPIS2_ENVIRONMENT=development
EPIS2_DATABASE_URL=postgresql+psycopg://epis2:epis2@localhost:5443/epis2
EPIS2_CORS_ORIGINS=["http://localhost:3100"]
EPIS2_AI_PROVIDER=ollama
EPIS2_OLLAMA_BASE_URL=http://localhost:11434
EPIS2_OLLAMA_MODEL=llama3.2:latest
EPIS2_OLLAMA_MODEL_SUMMARY=qwen3:8b
EPIS2_OLLAMA_MODEL_SUGGESTIONS=qwen3:8b
EPIS2_OLLAMA_MODEL_EMBEDDINGS=bge-m3
EPIS2_OLLAMA_TIMEOUT_SECONDS=60
EPIS2_AUTH_ENABLED=true
EPIS2_AUTH_SECRET=change-this-local-secret
EPIS2_AUTH_TOKEN_TTL_MINUTES=720
EPIS2_AUTH_ALLOW_DEV_ACTOR_HEADER=false
EPIS2_AUTH_LOCAL_USERS=admin@epis2.local|admin|Administrador Dev|admin,dev;medico@epis2.local|medico|Medico Dev|medico;enfermeria@epis2.local|enfermeria|Enfermeria Dev|enfermeria;lector@epis2.local|lector|Lectura Dev|solo_lectura

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8100
NEXT_PUBLIC_DEMO_MODE=false
