# EPIS2 — copiar a .env (no commitear .env)

# API clínica
NODE_ENV=development
# RLS_MODE=off en dev/test; staging/producción: enforce (ver .env.staging.example)
# RLS_MODE=off
API_HOST=0.0.0.0
API_PORT=3001
# Tests integración + paridad CI: docker compose postgres (host 5433) + npm run db:migrate
# Ver docs/quality/INTEGRATION_DATABASE.md
# API/tests: epis2_app (NOBYPASSRLS). Migraciones usan superuser epis2 automáticamente.
DATABASE_URL=postgresql://epis2_app:epis2@127.0.0.1:5433/epis2
# Opcional — override explícito de migraciones (Windows/Docker local):
# DATABASE_MIGRATE_URL=postgresql://epis2:epis2@127.0.0.1:5433/epis2

# Web (Vite) — vacío usa proxy /api en dev
VITE_API_BASE_URL=

# Catálogo UI interno (/dev/ui-catalog): activo en dev; en prod solo con true
# VITE_ENABLE_UI_CATALOG=true
# VITE_ENABLE_DESIGN_MODE=true

# Catálogo visual M3 (/desarrollo/catalogo-visual): activo en dev; en prod solo con true
# VITE_ENABLE_VISUAL_THEME_CATALOG=true

# Sesión API (cambiar en producción)
SESSION_SECRET=epis2-dev-session-secret-min-16-chars
SESSION_COOKIE_NAME=epis2_session
WEB_ORIGIN=http://127.0.0.1:5173

# IA local (Ollama)
AI_HOST=0.0.0.0
AI_PORT=3002
# Procesos Node en el host (npm run dev:ai / dev:api)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
# Dev agent — fallback si OLLAMA_ROUTE_MODE=fixed
OLLAMA_DEV_MODEL=qwen2.5-coder:14b
# Enrutado automático por estación + función (clinical | dev-plan | dev-write)
OLLAMA_ROUTE_MODE=auto
# EPIS2_WORKSTATION_TIER=performance
# EPIS2_WORKSTATION_VRAM_GB=12
# OLLAMA_ROUTE_DEV_PLAN=qwen2.5-coder:7b
# OLLAMA_ROUTE_DEV_WRITE=deepseek-coder-v2:16b
# Servicios en Docker → Ollama nativo en el host (ver docker-compose.yml):
# LANGUAGETOOL_BASE_URL=http://127.0.0.1:8010

# API → proxy hacia servicio local-ai
LOCAL_AI_BASE_URL=http://127.0.0.1:3002
