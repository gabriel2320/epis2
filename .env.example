# EPIS2 — copiar a .env (no commitear .env)

# API clínica
NODE_ENV=development
# RLS_MODE=off en dev/test; staging/producción: enforce (ver .env.staging.example)
# RLS_MODE=off
# Nivel de log pino del API (fatal|error|warn|info|debug|trace)
# LOG_LEVEL=info
# OpenTelemetry mínimo (MF-NORM-203) — off por defecto; ver docs/dev/EPIS2_OBSERVABILITY_OTEL.md
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_SERVICE_NAME=epis2-api
API_HOST=0.0.0.0
API_PORT=3001
# Tests integración + paridad CI: docker compose postgres (host 5433) + npm run db:migrate
# Ver docs/quality/INTEGRATION_DATABASE.md
# API/tests: epis2_app (NOBYPASSRLS). Migraciones usan superuser epis2 automáticamente.
DATABASE_URL=postgresql://epis2_app:epis2@127.0.0.1:5433/epis2
# Opcional — override explícito de migraciones (Windows/Docker local):
# DATABASE_MIGRATE_URL=postgresql://epis2:epis2@127.0.0.1:5433/epis2

# Web (Vite) — vacío usa proxy /api en dev
VITE_API_BASE_URL=

# Catálogo UI interno (/dev/ui-catalog): activo en dev; en prod solo con true
# VITE_ENABLE_UI_CATALOG=true
# VITE_ENABLE_DESIGN_MODE=true

# Catálogo visual M3 (/desarrollo/catalogo-visual): activo en dev; en prod solo con true
# VITE_ENABLE_VISUAL_THEME_CATALOG=true

# Spike Scheduler MUI-10 (/dev/scheduler-spike): activo en dev; en prod solo con true
# VITE_ENABLE_SCHEDULER_SPIKE=true

# Sesión API (cambiar en producción)
SESSION_SECRET=epis2-dev-session-secret-min-16-chars
SESSION_COOKIE_NAME=epis2_session
WEB_ORIGIN=http://127.0.0.1:5173

# IA local (Ollama)
AI_HOST=0.0.0.0
AI_PORT=3002
# Procesos Node en el host (npm run dev:ai / dev:api)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
# Dev agent — fallback si OLLAMA_ROUTE_MODE=fixed
OLLAMA_DEV_MODEL=qwen2.5-coder:14b
# Enrutado automático por estación + función (clinical | dev-plan | dev-write)
OLLAMA_ROUTE_MODE=auto
# EPIS2_WORKSTATION_TIER=performance
# EPIS2_WORKSTATION_VRAM_GB=12
# OLLAMA_ROUTE_DEV_PLAN=qwen2.5-coder:7b
# OLLAMA_ROUTE_DEV_WRITE=deepseek-coder-v2:16b
# Servicios en Docker → Ollama nativo en el host (ver docker-compose.yml):
# LanguageTool opcional: docker compose --profile languagetool up -d languagetool
# LANGUAGETOOL_BASE_URL=http://127.0.0.1:8010

# API → proxy hacia servicio local-ai
LOCAL_AI_BASE_URL=http://127.0.0.1:3002
# Opcional — endurecimiento pre-prod (misma clave en API y servicio local-ai):
# LOCAL_AI_API_KEY=epis2-local-ai-dev-key-min-16-chars

# Cursor MCP — GitHub (no commitear valor real; ver docs/dev/CURSOR_PLUGINS_EPIS2.md)
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Figma Code Connect — publish .figma.ts (scopes: Code Connect Write, File content Read)
# FIGMA_ACCESS_TOKEN=figd_...

# Dual chart modes ADR-002 (Entrega C-4)
# Signoff C-2 GO — staging/local: true · prod: decisión explícita del operador
# DEV: omitido = activo por defecto (dualChartModesEnv.ts)
VITE_ENABLE_DUAL_CHART_MODES=true
# Local: VITE_ENABLE_DUAL_CHART_MODES=true npm run dev -w @epis2/web
# E2E:  VITE_ENABLE_DUAL_CHART_MODES=true npm run test:e2e:dual-chart

# ── PM-03 Autodesarrollo 6 h (Ollama + Cursor + gates) ─────────────────────
# Obligatorio para commit/push automatizado del orquestador:
# EPIS2_AUTO_DEV_AUTHORIZED=1
# EPIS2_AUTO_DEV_DURATION_HOURS=6
# EPIS2_AUTO_DEV_TRAMO_PAUSE_MS=120000
# EPIS2_AUTO_DEV_OLLAMA=1
# EPIS2_AUTO_DEV_OLLAMA_APPLY=0
# EPIS2_AUTO_DEV_CURSOR_SDK=1
# EPIS2_AUTO_DEV_RESUME=1
# Cursor SDK (opcional — tramos Tier X con código producto):
# CURSOR_API_KEY=
# EPIS2_CURSOR_SDK_MODEL=composer-2.5
# Arranque: .\scripts\dev-agent\start-auto-dev-6h.ps1
# Manual: npm run dev:auto:orchestrate -- --commit --push

# ── Evolab (repo hermano epis2-evolab — sin importar código) ───────────────
# EPIS2_EVOLAB_ROOT=../epis2-evolab
# EPIS2_AUTO_DEV_EVOLAB=1
# EPIS2_EVOLAB_OPTIONAL=1

# ── OpenClaw MAX POWER (L3 auto-dev — ver epis2-auto-dev-locks.md) ───────
# EPIS2_OPENCLAW_ROOT=../openclaw-epis2
# EPIS2_OPENCLAW_SESSION=1
# EPIS2_OPENCLAW_MAX_POWER=1
# EPIS2_AUTO_DEV_OPENCLAW=1
# EPIS2_OPENCLAW_POWER_LEVEL=L3
# EPIS2_OPENCLAW_PATCHING_ENABLED=true
# EPIS2_OPENCLAW_SAFE_RUN=true
# EPIS2_OPENCLAW_AUTHORIZE_CONDITIONAL=true
# EPIS2_OPENCLAW_AUTHORIZE_CODE=true
# EPIS2_OPENCLAW_REQUIRE_HUMAN_APPROVAL=true
# EPIS2_OPENCLAW_GIT_WRITE=false
# EPIS2_OPENCLAW_READ_ENV=false
# L4 release-review: EPIS2_OPENCLAW_POWER_LEVEL=L4 (solo safe-run, sin patch)
