# EPIS2 — normalize text to LF (cross-platform; matches Prettier default)
* text=auto eol=lf

# Shell / script entrypoints (Windows batch may need CRLF if invoked by cmd.exe)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets — do not line-end normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.jar binary
*.wasm binary
*.mp4 binary
*.webm binary
*.sqlite binary
*.db binary

# Lockfiles and generated artifacts (text, LF)
package-lock.json text eol=lf
