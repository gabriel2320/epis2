{
  "name": "nightly",
  "description": "Paridad extendida con .github/workflows/ci.yml (job check). Requiere Postgres y tiempo.",
  "steps": [
    "npm run build:ci-fixtures-chain",
    "npm run db:migrate",
    "npm run quality:gate -- quality:case-intel-closure-gate",
    "npm run check",
    "npx prettier --check .",
    "npm run quality:gate -- quality:openapi-gate",
    "npm run quality:gate -- quality:pm01",
    "npm run quality:gate -- quality:layers-integration-gate",
    "npm run tool:script -- theme:validate",
    "npm run test -- --reporter=default --reporter=json --outputFile=reports/.vitest-ci-parity-temp.json",
    "npm run quality:gate -- quality:ci-parity -- --from-report=reports/.vitest-ci-parity-temp.json",
    "npm run build -w @epis2/web",
    "npm run test:e2e",
    "npm run db:validate",
    "npm run tool:script -- ai:evals",
    "npm run quality:gate -- quality:golden-journey",
    "npm run tool:script -- qa:bundle-analyze"
  ]
}
