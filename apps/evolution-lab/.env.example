# EPIS2 Evolab — copiar a apps/evolution-lab/.env o raíz .env

EPIS2_EVOLAB_ENABLED=true
EPIS2_EVOLAB_OLLAMA_URL=http://127.0.0.1:11434
EPIS2_EVOLAB_MODEL=qwen3:8b
EPIS2_EVOLAB_FAST_MODEL=
EPIS2_EVOLAB_EMBEDDING_MODEL=

# Eficiencia — API-first sin Chromium (recomendado para runs deterministas)
EPIS2_EVOLAB_BROWSER=false
EPIS2_EVOLAB_LLM_SIM=false
# off | plan | execute — execute corre PlanExecutor (FASE 9)
EPIS2_EVOLAB_OLLAMA_REQUIRED=false

EPIS2_EVOLAB_LLM_CONCURRENCY=1
EPIS2_EVOLAB_BROWSER_CONCURRENCY=1

EPIS2_EVOLAB_MAX_SCENARIO_ATTEMPTS=3
EPIS2_EVOLAB_MAX_REPRODUCTION_ATTEMPTS=2
EPIS2_EVOLAB_MAX_MODEL_ERRORS=2

EPIS2_EVOLAB_PATCHING_ENABLED=false
EPIS2_EVOLAB_REQUIRE_HUMAN_APPROVAL=true
EPIS2_EVOLAB_ALLOW_PUSH=false
EPIS2_EVOLAB_ALLOW_MERGE=false

# Target sandbox local
EPIS2_EVOLAB_TARGET_ID=epis2-local-sandbox
EPIS2_EVOLAB_WEB_BASE_URL=http://127.0.0.1:5173
EPIS2_EVOLAB_API_BASE_URL=http://127.0.0.1:3001

# Persistencia Evolab (FASE 2)
EPIS2_EVOLAB_DATABASE_URL=postgresql://epis2_evolab:epis2_evolab@127.0.0.1:5433/epis2_evolab
# Opcional — superuser para migraciones (default: epis2 desde DATABASE_URL evolab)
# EPIS2_EVOLAB_MIGRATE_URL=postgresql://epis2:epis2@127.0.0.1:5433/postgres

# Artefactos
EPIS2_EVOLAB_REPORTS_DIR=reports/evolution/runs
