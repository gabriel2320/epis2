{
  "name": "@epis2/epis2-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EPIS2 — capa UI Material UI (tema, primitivos, re-exports)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scheduler": {
      "types": "./dist/scheduler/index.d.ts",
      "import": "./dist/scheduler/index.js"
    },
    "./data": {
      "types": "./dist/data/public-core.d.ts",
      "import": "./dist/data/public-core.js"
    },
    "./charts": {
      "types": "./dist/charts/public-core.d.ts",
      "import": "./dist/charts/public-core.js"
    },
    "./clinical-chart-tabs": {
      "types": "./dist/cica/clinicalChartTabRegistry.d.ts",
      "import": "./dist/cica/clinicalChartTabRegistry.js"
    },
    "./tree": {
      "types": "./dist/tree/public-core.d.ts",
      "import": "./dist/tree/public-core.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@epis2/clinical-forms": "*",
    "@epis2/command-registry": "*",
    "@epis2/design-system": "*",
    "@mui/icons-material": "^6.4.11",
    "@mui/material": "^6.4.11",
    "@mui/x-charts": "^7.29.1",
    "@mui/x-data-grid": "^7.29.13",
    "@mui/x-date-pickers": "^7.29.4",
    "@mui/x-scheduler": "^9.0.0-alpha.4",
    "@mui/x-tree-view": "^7.29.10",
    "@hookform/resolvers": "^5.0.1",
    "dayjs": "^1.11.21",
    "react-hook-form": "^7.56.4",
    "zod": "^3.25.42"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^8.6.18",
    "typescript": "^5.8.3",
    "vite": "^6.4.3"
  }
}
