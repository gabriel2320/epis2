{
  "name": "@epis2/ai-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./commandAssistDraft": {
      "types": "./dist/commandAssistDraft.d.ts",
      "import": "./dist/commandAssistDraft.js"
    },
    "./contextPanelSuggestions": {
      "types": "./dist/contextPanelSuggestions.d.ts",
      "import": "./dist/contextPanelSuggestions.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@epis2/contracts": "*"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  }
}
