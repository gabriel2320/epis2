{
  "name": "epis2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EPIS2 — aplicación clínica command-first",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build -w @epis2/contracts && npm run build -w @epis2/clinical-domain && npm run build -w @epis2/design-system && npm run build -w @epis2/command-registry && npm run build -w @epis2/clinical-forms && npm run build -w @epis2/epis2-widgets && npm run build -w @epis2/epis2-ui && npm run build -w @epis2/test-fixtures && npm run build -w @epis2/fhir-export && npm run build -w @epis2/local-ai && npm run build -w @epis2/api && npm run build -w @epis2/web",
    "lint": "eslint .",
    "typecheck": "npm run build -w @epis2/contracts && npm run build -w @epis2/clinical-domain && npm run build -w @epis2/design-system && npm run build -w @epis2/command-registry && npm run build -w @epis2/clinical-forms && npm run build -w @epis2/epis2-widgets && npm run build -w @epis2/epis2-ui && npm run build -w @epis2/test-fixtures && npm run build -w @epis2/fhir-export && npm run build -w @epis2/local-ai && npm run typecheck -w @epis2/contracts && npm run typecheck -w @epis2/clinical-domain && npm run typecheck -w @epis2/design-system && npm run typecheck -w @epis2/command-registry && npm run typecheck -w @epis2/clinical-forms && npm run typecheck -w @epis2/epis2-widgets && npm run typecheck -w @epis2/epis2-ui && npm run typecheck -w @epis2/test-fixtures && npm run typecheck -w @epis2/fhir-export && npm run typecheck -w @epis2/local-ai && npm run typecheck -w @epis2/api && npm run typecheck -w @epis2/web",
    "test": "npm run build -w @epis2/contracts && npm run build -w @epis2/clinical-domain && npm run build -w @epis2/design-system && npm run build -w @epis2/command-registry && npm run build -w @epis2/clinical-forms && npm run build -w @epis2/epis2-widgets && npm run build -w @epis2/epis2-ui && npm run build -w @epis2/test-fixtures && npm run build -w @epis2/fhir-export && vitest run",
    "architecture:validate": "node scripts/architecture/validate-all.mjs",
    "qa:bundle-analyze": "node scripts/qa/bundle-analyze.mjs",
    "quality:m3-signoff": "node scripts/quality/verify-m3-signoff.mjs",
    "quality:m3-human-pilot": "node scripts/quality/run-m3-human-pilot.mjs",
    "quality:m3-visual-pass": "node scripts/quality/capture-m3-visual-pass.mjs",
    "quality:pilot-trial": "node scripts/quality/run-pilot-trial.mjs",
    "quality:microphases": "node scripts/quality/validate-microphase-ledger.mjs",
    "quality:microphase-next": "node scripts/quality/microphase-next.mjs",
    "quality:ci-parity": "node scripts/quality/validate-ci-test-parity.mjs",
    "quality:local-ci": "node scripts/quality/run-local-ci.mjs",
    "stack:up": "node scripts/stack-up.mjs",
    "quality:ola2-m3-ui-gate": "node scripts/quality/validate-ola2-m3-ui-gate.mjs",
    "quality:ola2-physical-exam-gate": "node scripts/quality/validate-ola2-physical-exam-gate.mjs",
    "quality:ola1c-journey-gate": "node scripts/quality/validate-ola1c-journey-gate.mjs",
    "quality:ola3-ficha-gate": "node scripts/quality/validate-ola3-ficha-gate.mjs",
    "quality:ola3-alerts-gate": "node scripts/quality/validate-ola3-alerts-gate.mjs",
    "quality:ola6a-print-gate": "node scripts/quality/validate-ola6a-print-gate.mjs",
    "quality:doc-screen-catalog-gate": "node scripts/quality/validate-doc-screen-catalog-gate.mjs",
    "quality:ola3-longitudinal-gate": "node scripts/quality/validate-ola3-longitudinal-gate.mjs",
    "quality:ola3-ficha-depth-gate": "node scripts/quality/validate-ola3-ficha-depth-gate.mjs",
    "quality:ola3-ficha-hub-gate": "node scripts/quality/validate-ola3-ficha-hub-gate.mjs",
    "quality:ola3-surgical-gate": "node scripts/quality/validate-ola3-surgical-gate.mjs",
    "quality:ola1c-imaging-gate": "node scripts/quality/validate-ola1c-imaging-gate.mjs",
    "quality:tramo-b-reception-gate": "node scripts/quality/validate-tramo-b-reception-gate.mjs",
    "quality:tramo-a-closure-gate": "node scripts/quality/validate-tramo-a-closure-gate.mjs",
    "quality:tramo-b-ui-gate": "node scripts/quality/validate-tramo-b-ui-gate.mjs",
    "quality:tramo-c-emergency-gate": "node scripts/quality/validate-tramo-c-emergency-gate.mjs",
    "quality:tramo-d-inventory-gate": "node scripts/quality/validate-tramo-d-inventory-gate.mjs",
    "test:e2e:tramo-b": "playwright test e2e/tramo-b-reception.spec.ts",
    "test:e2e:tramo-c": "playwright test e2e/tramo-c-emergency.spec.ts",
    "test:e2e:ola2": "playwright test e2e/ola2-ambulatory-m3-ui.spec.ts",
    "test:e2e:ola1c": "playwright test e2e/ola1c-results-journey.spec.ts",
    "test:e2e:ola3": "playwright test e2e/ola3-ficha-journey.spec.ts",
    "test:e2e:install": "playwright install chromium",
    "quality:golden-journey": "npm run build -w @epis2/command-registry && npm run build -w @epis2/clinical-forms && npm run build -w @epis2/test-fixtures && vitest run tests/golden-clinical-journey.spec.ts tests/golden-clinical-journey.api.spec.ts",
    "check": "npm run lint && npm run typecheck && npm run architecture:validate",
    "db:validate": "node scripts/db-validate.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:backup": "node scripts/epis-db-backup.mjs",
    "db:restore": "node scripts/epis-db-restore.mjs",
    "db:apply-latest": "node scripts/quality/apply-latest-migration.mjs",
    "dev:api": "npm run dev -w @epis2/api",
    "dev:web": "npm run dev -w @epis2/web",
    "dev:ai": "npm run dev -w @epis2/local-ai",
    "ai:enable": "node scripts/ai-local-enable.mjs",
    "ai:smoke": "node scripts/ai-smoke.mjs",
    "ai:evals": "npm run build -w @epis2/local-ai && node scripts/ai-synthetic-evals.mjs",
    "ai:pull-model": "ollama pull qwen3:8b",
    "legacy:audit": "node scripts/legacy-audit/scan-donor-repositories.mjs && node scripts/legacy-audit/detect-forbidden-dependencies.mjs && node scripts/legacy-audit/detect-secrets-and-sensitive-data.mjs && node scripts/legacy-audit/detect-duplicate-registries.mjs && node scripts/legacy-audit/detect-legacy-routes.mjs",
    "legacy:validate-manifest": "node scripts/legacy-audit/validate-import-manifest.mjs",
    "legacy:validate-quarantine": "node scripts/legacy-audit/validate-quarantine.mjs",
    "theme:import": "node scripts/theme/import-material-theme.mjs",
    "theme:generate": "node scripts/theme/generate-epis2-theme.mjs",
    "theme:validate": "node scripts/theme/validate-theme-all.mjs",
    "theme:report": "node scripts/theme/generate-theme-report.mjs",
    "theme:snapshot": "node scripts/theme/compare-theme-snapshots.mjs"
  },
  "overrides": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^22.15.21",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "postgres": "^3.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=20"
  }
}
