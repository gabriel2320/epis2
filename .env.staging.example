# EPIS2 — perfil staging / pre-piloto (copiar y ajustar; no commitear secretos reales)
# Ver docs/ops/RLS_STAGING_RUNBOOK.md

NODE_ENV=staging
API_HOST=0.0.0.0
API_PORT=3001
DATABASE_URL=postgresql://epis2_app:CHANGE_ME@db-host:5432/epis2

# Fail-closed obligatorio en staging (MF-CON-04)
RLS_MODE=enforce

# Min 32 caracteres — no usar default dev (MF-CON-04)
SESSION_SECRET=
SESSION_COOKIE_NAME=epis2_session
WEB_ORIGIN=https://staging.epis2.example

LOCAL_AI_BASE_URL=http://127.0.0.1:3002
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Demo login deshabilitado en staging — hybrid/service key u OIDC futuro (MF-CON-05)
AUTH_MODE=hybrid
# SERVICE_API_KEY=CHANGE_ME_MIN_32_CHARS_SERVICE_KEY

# Dual chart ADR-002 — activo en staging post signoff C-2 (Entrega C-4)
VITE_ENABLE_DUAL_CHART_MODES=true
