# EPIS2 — perfil staging / pre-piloto (copiar y ajustar; no commitear secretos reales)
# Ver docs/ops/RLS_STAGING_RUNBOOK.md

NODE_ENV=production
API_HOST=0.0.0.0
API_PORT=3001
DATABASE_URL=postgresql://epis2:CHANGE_ME@db-host:5432/epis2

# Fail-closed obligatorio en staging
RLS_MODE=enforce

SESSION_SECRET=CHANGE_ME_MIN_32_CHARS_STAGING_SECRET
SESSION_COOKIE_NAME=epis2_session
WEB_ORIGIN=https://staging.epis2.example

LOCAL_AI_BASE_URL=http://127.0.0.1:3002
OLLAMA_BASE_URL=http://127.0.0.1:11434
AUTH_MODE=demo
