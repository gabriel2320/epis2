# EPIS2 — perfil producción (plantilla; no commitear secretos reales)
# Ver docs/ops/EPIS2_DUAL_CHART_PROD_ROLLOUT.md

NODE_ENV=production
API_HOST=0.0.0.0
API_PORT=3001
DATABASE_URL=postgresql://epis2_app:CHANGE_ME@db-host:5432/epis2

RLS_MODE=enforce

SESSION_SECRET=CHANGE_ME_MIN_32_CHARS_PRODUCTION_SECRET
SESSION_COOKIE_NAME=epis2_session
WEB_ORIGIN=https://epis2.example

# Dual chart ADR-002 — activar tras signoff C-2 GO y validación staging
VITE_ENABLE_DUAL_CHART_MODES=true

AUTH_MODE=production
